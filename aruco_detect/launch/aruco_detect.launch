<launch>

  <arg name="camera" default="/camera/color"/>

  <node pkg="aruco_detect"
        type="aruco_detect"
        name="aruco_detect"
        output="screen">

    <param name="image_transport" value="raw"/>
    <param name="publish_images" value="true"/>
    <param name="fiducial_len" value="0.14"/>
    <param name="dictionary" value="3"/>
    <param name="do_pose_estimation" value="true"/>
    <param name="verbose" value="true"/>

    <!-- สำคัญที่สุด -->
    <remap from="camera/image_raw"
           to="/camera/color/image_raw"/>

    <remap from="camera_info"
           to="/camera/color/camera_info"/>

  </node>

</launch>
