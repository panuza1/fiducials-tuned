<launch>
  <arg name="map_frame" default="map"/>
  <arg name="odom_frame" default="odom"/>
  <arg name="base_frame" default="base_footprint"/>
  
  <arg name="mapping_mode" default="true" 
       doc="true = สร้างแผนที่อัตโนมัติ, false = localization เท่านั้น"/>
  <arg name="do_pose_estimation" default="true"/>

  <arg name="min_fiducial_observations" default="2"/>
  <arg name="max_variance" default="2.0"/>

  <arg name="publish_tf" default="true"/>
  <arg name="tf_publish_interval" default="0.1"/>
  <arg name="future_date_transforms" default="0.1"/>

  <arg name="publish_6dof_pose" default="true"/>
  <arg name="publish_markers" default="true"/> <arg name="verbose" default="true"/>

  <node type="fiducial_slam" pkg="fiducial_slam" output="screen" name="fiducial_slam">
    
    <param name="map_file" value="$(env HOME)/.ros/slam/map.txt"/>
    <param name="obs_file" value="$(env HOME)/.ros/slam/observations.txt"/>
    
    <param name="map_frame" value="$(arg map_frame)"/>
    <param name="odom_frame" value="$(arg odom_frame)"/>
    <param name="base_frame" value="$(arg base_frame)"/>
    
    <param name="publish_tf" value="$(arg publish_tf)"/>
    <param name="tf_publish_interval" value="$(arg tf_publish_interval)"/>
    <param name="future_date_transforms" value="$(arg future_date_transforms)"/>
    <param name="publish_6dof_pose" value="$(arg publish_6dof_pose)"/>
    <param name="pose_publish_rate" value="20"/>
    
    <param name="do_pose_estimation" value="$(arg do_pose_estimation)"/>
    <param name="mapping_mode" value="$(arg mapping_mode)"/>
    <param name="sum_error_in_quadrature" value="true"/>
    
    <param name="min_fiducial_observations" value="$(arg min_fiducial_observations)"/>
    <param name="max_variance" value="$(arg max_variance)"/>
    <param name="multi_marker_reinference" value="true"/>
    
    <param name="systematic_error" value="0.05"/>
    <rosparam param="covariance_diagonal" subst_value="True">[0.05, 0.05, 0.05, 0.1, 0.1, 0.1]</rosparam>
    
    <param name="publish_markers" value="$(arg publish_markers)"/>
    <param name="verbose" value="$(arg verbose)"/>
  </node>

  <node pkg="rosbash" type="roshrun" name="create_slam_dir" 
        args="bash -c 'mkdir -p $(env HOME)/.ros/slam'" 
        launch-prefix="" output="screen"/>

  </launch>